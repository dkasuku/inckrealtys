# Copy to .env and edit

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/inck_realty

# --- Security ---
SECRET_KEY=replace-with-a-long-random-string
JWT_EXPIRES_HOURS=12

# --- Seeded admin login (used by `python seed.py`) ---
ADMIN_EMAIL=admin@inckrealty.co.ke
ADMIN_PASSWORD=ChangeMe123!

# --- Uploads ---
# Defaults to ../nextjs/public/uploads so Next.js serves images at /uploads/<file>
# UPLOAD_DIR=
UPLOAD_URL_PREFIX=/uploads
MAX_UPLOAD_MB=10

# --- CORS: the Next.js origin ---
CORS_ORIGINS=http://localhost:3000

# --- Railway deployment notes ---
# On Railway these values come from the service Variables tab instead of this file.
# UPLOAD_DIR=/app/uploads
# UPLOAD_URL_PREFIX=https://<your-backend-domain>/uploads
# CORS_ORIGINS=https://<your-frontend-domain>
